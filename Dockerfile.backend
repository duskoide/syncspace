# Minimal Backend Dockerfile
# Binary is built locally and volume-mounted — no build stage needed.
FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app

# Create directories for data and uploads
RUN mkdir -p /data /uploads

EXPOSE 8080

ENV SYNCSPACE_ADDR=:8080
ENV SYNCSPACE_DB_PATH=/data/syncspace.db
ENV SYNCSPACE_UPLOAD_DIR=/uploads

CMD ["./syncspace"]
