# Backend Dockerfile
# Binary is built locally and copied into the image.
FROM alpine:latest
RUN apk --no-cache add ca-certificates
WORKDIR /app

COPY backend/bin/syncspace ./syncspace
RUN chmod +x ./syncspace

RUN mkdir -p /data /uploads

EXPOSE 8080

ENV SYNCSPACE_ADDR=:8080
ENV SYNCSPACE_DB_PATH=/data/syncspace.db
ENV SYNCSPACE_UPLOAD_DIR=/uploads

CMD ["./syncspace"]
