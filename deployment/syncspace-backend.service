[Unit]
Description=SyncSpace Backend
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/syncspace/backend
Environment=SYNCSPACE_ADDR=:8080
Environment=SYNCSPACE_DB_PATH=/opt/syncspace/data/syncspace.db
ExecStart=/usr/local/go/bin/go run ./cmd/syncspace
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
